[
  {
    "id": "water:audit-draw",
    "title": "Audit water allocation",
    "domain": "water",
    "tags": ["water"],
    "why_template": "Drawing {water.daily_total} gal/day but household need is {water.daily_household} gal. Gap of {water.unexplained_draw} gal is unexplained. No significant rain forecast for {weather.dry_days_ahead} days.",
    "impact": {
      "resource": "water",
      "metric": "daily_draw",
      "delta": -1,
      "confidence": "low"
    },
    "preconditions": [
      { "field": "water.daily_total",              "op": "gt",  "value": 0 },
      { "field": "water.unexplained_draw",          "op": "gt",  "value": 0.5 },
      { "field": "weather.precip_forecast_14d",     "op": "lt",  "value": 0.5 }
    ],
    "window": {
      "hours": null,
      "months": null,
      "zone_adjusted": false
    },
    "effort": {
      "minutes": 30,
      "intensity": "light",
      "requires_presence": true
    },
    "recurrence": {
      "type": "state_triggered",
      "cooldown_after_completion": 14
    },
    "dismissal": {
      "options": ["done", "already_handled", "not_relevant"],
      "resurface_on_state_change": true,
      "state_change_threshold": 0.25
    }
  },
