# Resend (existing — email capture and order delivery)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...

# Survival Garden Plan — LemonSqueezy checkout (Sprint 1 MVP)
# Get these from your LS dashboard after creating the store + product variant.
# Without these, /api/survival-garden-plan/checkout/ returns the PDF directly in dev mode
# and 503s in production.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Email sender used for order delivery (defaults to orders@homesteaderlabs.com)
SGP_FROM_EMAIL=orders@homesteaderlabs.com

# Public site URL — used in QR codes, redirect URLs, affiliate link companion pages.
NEXT_PUBLIC_SITE_URL=https://homesteaderlabs.com
